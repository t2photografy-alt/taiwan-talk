{
  "name": "taiwan-talk",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "qa:flow": "node scripts/run-playwright.mjs tests/e2e/user-flows.spec.ts",
    "qa:flow:headed": "node scripts/run-playwright.mjs tests/e2e/user-flows.spec.ts --headed",
    "qa:screenshots": "node scripts/run-playwright.mjs tests/e2e/screenshots.spec.ts",
    "qa:ai-generation": "node scripts/run-ai-generation-qa.mjs",
    "qa:tts": "node --experimental-strip-types scripts/run-tts-qa.mjs",
    "qa:api-contract": "node --experimental-strip-types scripts/run-api-contract-qa.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "latest",
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "motion": "latest",
    "openai": "^6.45.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "latest"
  }
}
